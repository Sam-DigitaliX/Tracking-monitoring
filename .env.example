# ======================
# TrackGuard - Environment Variables
# Copy this file to .env and fill in your values
# ======================

# --- Database (Coolify-managed PostgreSQL) ---
# Use the "Postgres URL (Internal)" from your Coolify database resource
# Replace postgres:// with postgresql+asyncpg:// for the async driver
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@YOUR_COOLIFY_DB_HOST:5432/postgres

# --- App ---
APP_ENV=production
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# --- Alerts - Slack (optional) ---
SLACK_WEBHOOK_URL=

# --- Alerts - Email SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@yourdomain.com
