# ======================
# TrackGuard - Environment Variables
# Copy this file to .env and fill in your values
# ======================

# --- Database ---
POSTGRES_USER=trackguard
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=trackguard

# --- App ---
APP_ENV=production
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# --- Alerts - Slack (optional) ---
SLACK_WEBHOOK_URL=

# --- Alerts - Email SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@yourdomain.com
